<?xml version="1.0"?>
<!-- Quadbot - CHAMP-compatible 12-DOF quadruped (xacro).
     Each leg is the standard mammalian 3-DOF chain that CHAMP requires.
     hip   - abduction, rotates about X (swings the leg sideways)
     upper - thigh pitch, rotates about Y
     lower - knee pitch, rotates about Y
     Link names follow CHAMP auto-config (hip / upper_leg / lower_leg / foot),
     legs are lf rf lh rh, all joint origin rpy are zero, and at zero angles the
     legs hang straight down (perpendicular to the ground) as CHAMP expects.
     Bright yellow markers sit on each joint, aligned with its rotation axis. -->
<robot name="quadbot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================ dimensions ============================ -->
  <xacro:property name="body_len"  value="0.40"/>
  <xacro:property name="body_wid"  value="0.18"/>
  <xacro:property name="body_hgt"  value="0.08"/>
  <xacro:property name="body_mass" value="3.0"/>

  <xacro:property name="hip_off"   value="0.05"/>   <!-- lateral hip -> upper leg -->
  <xacro:property name="upper_len" value="0.14"/>
  <xacro:property name="lower_len" value="0.14"/>
  <xacro:property name="leg_rad"   value="0.018"/>
  <xacro:property name="foot_rad"  value="0.025"/>

  <xacro:property name="hip_x" value="0.14"/>
  <xacro:property name="hip_y" value="0.09"/>
  <xacro:property name="hip_z" value="-0.02"/>

  <xacro:property name="j_eff" value="40.0"/>
  <xacro:property name="j_vel" value="12.0"/>

  <!-- ============================ materials ============================= -->
  <material name="body_blue"><color rgba="0.15 0.35 0.85 1"/></material>
  <material name="leg_dark"><color rgba="0.2 0.2 0.22 1"/></material>
  <material name="foot_grey"><color rgba="0.05 0.05 0.05 1"/></material>
  <material name="joint_yellow"><color rgba="1.0 0.8 0.0 1"/></material>

  <!-- ========================== inertia helpers ======================== -->
  <xacro:macro name="box_inertia" params="m x y z">
    <inertia ixx="${m*(y*y+z*z)/12.0}" ixy="0" ixz="0"
             iyy="${m*(x*x+z*z)/12.0}" iyz="0"
             izz="${m*(x*x+y*y)/12.0}"/>
  </xacro:macro>
  <xacro:macro name="cyl_inertia" params="m r l">
    <inertia ixx="${m*(3.0*r*r+l*l)/12.0}" ixy="0" ixz="0"
             iyy="${m*(3.0*r*r+l*l)/12.0}" iyz="0"
             izz="${m*r*r/2.0}"/>
  </xacro:macro>
  <xacro:macro name="sphere_inertia" params="m r">
    <inertia ixx="${0.4*m*r*r}" ixy="0" ixz="0"
             iyy="${0.4*m*r*r}" iyz="0" izz="${0.4*m*r*r}"/>
  </xacro:macro>

  <!-- ============================== body =============================== -->
  <link name="base_link">
    <visual>
      <geometry><box size="${body_len} ${body_wid} ${body_hgt}"/></geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <geometry><box size="${body_len} ${body_wid} ${body_hgt}"/></geometry>
    </collision>
    <inertial>
      <mass value="${body_mass}"/>
      <xacro:box_inertia m="${body_mass}" x="${body_len}" y="${body_wid}" z="${body_hgt}"/>
    </inertial>
  </link>

  <!-- =============================== leg =============================== -->
  <!-- prefix lf/rf/lh/rh, (px,py) hip mount, ydir +1 left / -1 right -->
  <xacro:macro name="leg" params="prefix px py ydir">

    <!-- hip abduction joint (axis X) -->
    <joint name="${prefix}_hip_joint" type="revolute">
      <parent link="base_link"/>
      <child  link="${prefix}_hip_link"/>
      <origin xyz="${px} ${py} ${hip_z}" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-0.8" upper="0.8" effort="${j_eff}" velocity="${j_vel}"/>
      <dynamics damping="0.2" friction="0.0"/>
    </joint>
    <link name="${prefix}_hip_link">
      <visual>
        <origin xyz="0 ${ydir*hip_off/2} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.025" length="${hip_off}"/></geometry>
        <material name="body_blue"/>
      </visual>
      <collision>
        <origin xyz="0 ${ydir*hip_off/2} 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.025" length="${hip_off}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 ${ydir*hip_off/2} 0"/>
        <mass value="0.2"/>
        <xacro:box_inertia m="0.2" x="0.05" y="${hip_off}" z="0.05"/>
      </inertial>
      <!-- joint marker, hip turns about X so the rod lies along X -->
      <visual>
        <origin xyz="0 0 0" rpy="0 1.5708 0"/>
        <geometry><cylinder radius="0.022" length="0.075"/></geometry>
        <material name="joint_yellow"/>
      </visual>
    </link>

    <!-- upper leg pitch joint (axis Y) -->
    <joint name="${prefix}_upper_leg_joint" type="revolute">
      <parent link="${prefix}_hip_link"/>
      <child  link="${prefix}_upper_leg_link"/>
      <origin xyz="0 ${ydir*hip_off} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="${j_eff}" velocity="${j_vel}"/>
      <dynamics damping="0.2" friction="0.0"/>
    </joint>
    <link name="${prefix}_upper_leg_link">
      <visual>
        <origin xyz="0 0 ${-upper_len/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_rad}" length="${upper_len}"/></geometry>
        <material name="leg_dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-upper_len/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_rad}" length="${upper_len}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-upper_len/2}"/>
        <mass value="0.25"/>
        <xacro:cyl_inertia m="0.25" r="${leg_rad}" l="${upper_len}"/>
      </inertial>
      <!-- joint marker, pitch about Y so the rod lies along Y -->
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.022" length="0.06"/></geometry>
        <material name="joint_yellow"/>
      </visual>
    </link>

    <!-- lower leg / knee pitch joint (axis Y) -->
    <joint name="${prefix}_lower_leg_joint" type="revolute">
      <parent link="${prefix}_upper_leg_link"/>
      <child  link="${prefix}_lower_leg_link"/>
      <origin xyz="0 0 ${-upper_len}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="${j_eff}" velocity="${j_vel}"/>
      <dynamics damping="0.2" friction="0.0"/>
    </joint>
    <link name="${prefix}_lower_leg_link">
      <visual>
        <origin xyz="0 0 ${-lower_len/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_rad}" length="${lower_len}"/></geometry>
        <material name="leg_dark"/>
      </visual>
      <collision>
        <origin xyz="0 0 ${-lower_len/2}" rpy="0 0 0"/>
        <geometry><cylinder radius="${leg_rad}" length="${lower_len}"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 ${-lower_len/2}"/>
        <mass value="0.2"/>
        <xacro:cyl_inertia m="0.2" r="${leg_rad}" l="${lower_len}"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0" rpy="1.5708 0 0"/>
        <geometry><cylinder radius="0.022" length="0.06"/></geometry>
        <material name="joint_yellow"/>
      </visual>
    </link>

    <!-- foot (fixed, point contact) -->
    <joint name="${prefix}_foot_joint" type="fixed">
      <parent link="${prefix}_lower_leg_link"/>
      <child  link="${prefix}_foot_link"/>
      <origin xyz="0 0 ${-lower_len}" rpy="0 0 0"/>
    </joint>
    <link name="${prefix}_foot_link">
      <visual>
        <origin xyz="0 0 -0.0175" rpy="0 0 0"/>
        <geometry><box size="0.045 0.05 0.035"/></geometry>
        <material name="foot_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 -0.0175" rpy="0 0 0"/>
        <geometry><box size="0.045 0.05 0.035"/></geometry>
      </collision>
      <inertial>
        <origin xyz="0 0 -0.0175" rpy="0 0 0"/>
        <mass value="0.05"/>
        <xacro:box_inertia m="0.05" x="0.045" y="0.05" z="0.035"/>
      </inertial>
    </link>
    <gazebo reference="${prefix}_foot_link">
      <mu1>1.2</mu1>
      <mu2>1.2</mu2>
      <kp>100000.0</kp>
      <kd>1.0</kd>
      <minDepth>0.001</minDepth>
    </gazebo>
  </xacro:macro>

  <xacro:leg prefix="lf" px="${ hip_x}" py="${ hip_y}" ydir="1"/>
  <xacro:leg prefix="rf" px="${ hip_x}" py="${-hip_y}" ydir="-1"/>
  <xacro:leg prefix="lh" px="${-hip_x}" py="${ hip_y}" ydir="1"/>
  <xacro:leg prefix="rh" px="${-hip_x}" py="${-hip_y}" ydir="-1"/>

  <!-- NOTE: No ros2_control / gazebo_ros2_control block here on purpose.
       The CHAMP setup assistant only needs the kinematic chain (links + joints)
       from robot_description, and CHAMP generates its own controllers and
       gazebo bringup later. The old gazebo_ros2_control plugin (which pointed
       at a config in a package named quadbot_nodes) was removed because that
       package does not exist in this workspace and it broke xacro expansion. -->

</robot>
